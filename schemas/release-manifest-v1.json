{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spack-composer.example/schemas/release-manifest-v1.json",
  "title": "Spack stack release manifest (v1)",
  "description": "The single file tying a release to its source inputs, build context, and buildcache destinations. Exists in two phases: draft (after render, build-context fields null/absent) and final (after publish-manifest, all fields present). Mirrors docs/spack_stack_generation_design_v6.md § Release Manifest Schema.",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Manifest schema version. v1 is this file."
    },
    "phase": {
      "type": "string",
      "enum": ["draft", "final"],
      "description": "draft: written by render; build-context fields null. final: rewritten by publish-manifest with build-context filled."
    },
    "release": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Release tag."
        },
        "rendered_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$",
          "description": "ISO-8601 UTC timestamp explicitly passed as a render variable."
        },
        "promoted_at": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "string",
              "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
            }
          ],
          "description": "Filled at publish only when promotion actually happens. Null in draft and in pre-promotion final."
        },
        "promoted_by": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ],
          "description": "Operator id of the human who promoted the release. Null when not yet promoted."
        }
      },
      "required": ["name", "rendered_at"],
      "additionalProperties": false
    },
    "stack": {
      "type": "object",
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "source_repo": { "type": "string", "minLength": 1, "description": "Repository URL." },
        "source_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{7,64}$",
          "description": "Exact commit the render used."
        },
        "source_dirty": {
          "type": "boolean",
          "description": "True if the working tree had uncommitted changes at render."
        }
      },
      "required": ["name", "source_repo", "source_commit", "source_dirty"],
      "additionalProperties": false
    },
    "profile": {
      "type": "object",
      "properties": {
        "path": { "type": "string", "minLength": 1, "description": "Path within the source repo." },
        "digest": { "$ref": "#/$defs/sha256_digest" },
        "system_name": {
          "type": "string",
          "minLength": 1,
          "description": "Cross-check against profile.system.name."
        }
      },
      "required": ["path", "digest", "system_name"],
      "additionalProperties": false
    },
    "stack_file": {
      "type": "object",
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "digest": { "$ref": "#/$defs/sha256_digest" }
      },
      "required": ["path", "digest"],
      "additionalProperties": false
    },
    "package_sets": {
      "type": "array",
      "description": "One entry per unique package_set file. Empty if all specs are inline.",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "digest": { "$ref": "#/$defs/sha256_digest" }
        },
        "required": ["name", "path", "digest"],
        "additionalProperties": false
      }
    },
    "templates": {
      "type": "object",
      "properties": {
        "set": { "type": "string", "minLength": 1 },
        "digest": { "$ref": "#/$defs/sha256_digest" },
        "defaults_digest": { "$ref": "#/$defs/sha256_digest" },
        "contract_digest": { "$ref": "#/$defs/sha256_digest" },
        "render_tool": {
          "type": "object",
          "description": "Which render step produced this workspace.",
          "properties": {
            "name": { "type": "string", "minLength": 1, "description": "e.g., 'spack-composer render' or 'manual'." },
            "version": {
              "oneOf": [
                { "type": "null" },
                { "type": "string", "minLength": 1 }
              ],
              "description": "Tool version. Null when name is 'manual'."
            }
          },
          "required": ["name", "version"],
          "additionalProperties": false
        },
        "applied_narrowing": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/applied_narrowing_block" }
          ],
          "description": "Null when no per_system block matched profile.system.name. Otherwise a record of which axes the narrowing dropped candidates on."
        }
      },
      "required": ["set", "digest", "defaults_digest", "contract_digest", "render_tool"],
      "additionalProperties": false
    },
    "spack": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/spack_block" }
      ],
      "description": "Spack build-context. Null in draft; required in final."
    },
    "build_host": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/build_host_block" }
      ],
      "description": "Build-host facts. Null in draft; required in final."
    },
    "lanes": {
      "type": "array",
      "description": "One entry per rendered lane. Render-filled fields are always present; publish-filled fields are absent or null until publish-manifest runs.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/lane_entry"
      }
    },
    "skipped_builds": {
      "type": "array",
      "description": "Render-filled. Empty if every requested build rendered. Non-empty entries carry a stable reason_code plus a human reason.",
      "items": {
        "type": "object",
        "properties": {
          "build": { "type": "string", "minLength": 1 },
          "reason_code": {
            "type": "string",
            "enum": [
              "per_system_empty",
              "nodes_unmatched",
              "requires_unsatisfied",
              "template_not_supported"
            ]
          },
          "reason": { "type": "string", "minLength": 1 }
        },
        "required": ["build", "reason_code", "reason"],
        "additionalProperties": false
      }
    },
    "buildcache": {
      "type": "object",
      "description": "Buildcache push results. push_destinations is render-empty in draft and filled at publish.",
      "properties": {
        "push_destinations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "url": { "type": "string", "minLength": 1 },
              "lanes_pushed": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            },
            "required": ["name", "url", "lanes_pushed"],
            "additionalProperties": false
          }
        },
        "planned_destinations": {
          "type": "array",
          "description": "Optional. Render may pre-populate this for Ansible to consult.",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "url": { "type": "string", "minLength": 1 }
            },
            "required": ["name", "url"],
            "additionalProperties": false
          }
        },
        "signed": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "verification": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/verification_block" }
      ],
      "description": "Verification results. Null in draft; required in final."
    },
    "previous_release": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ],
      "description": "Previous release tag from the `current` symlink before promotion. Null on first release or in draft."
    }
  },
  "required": [
    "schema_version",
    "phase",
    "release",
    "stack",
    "profile",
    "stack_file",
    "templates",
    "lanes",
    "skipped_builds"
  ],
  "additionalProperties": false,
  "allOf": [
    {
      "if": { "properties": { "phase": { "const": "final" } } },
      "then": {
        "required": ["spack", "build_host", "verification"],
        "properties": {
          "spack": { "$ref": "#/$defs/spack_block" },
          "build_host": { "$ref": "#/$defs/build_host_block" },
          "verification": { "$ref": "#/$defs/verification_block" },
          "lanes": {
            "type": "array",
            "items": {
              "allOf": [
                { "$ref": "#/$defs/lane_entry" },
                { "$ref": "#/$defs/lane_entry_final_requirements" }
              ]
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "sha256_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "description": "SHA-256 digest with sha256: prefix."
    },
    "applied_narrowing_block": {
      "type": "object",
      "properties": {
        "system": {
          "type": "string",
          "minLength": 1,
          "description": "Which per_system.<system> key matched."
        },
        "builds": {
          "type": "object",
          "description": "One entry per build whose narrowing dropped at least one candidate.",
          "minProperties": 1,
          "patternProperties": {
            "^[a-z][a-z0-9_-]*$": {
              "type": "object",
              "properties": {
                "dropped_lanes": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 }
                },
                "narrowed_by": {
                  "type": "object",
                  "description": "One entry per axis that actually dropped a contract-resolved candidate. Per_system axes whose narrowing was a no-op on this profile are not recorded.",
                  "minProperties": 1,
                  "patternProperties": {
                    "^[a-z][a-z0-9_]*$": {
                      "type": "object",
                      "properties": {
                        "kept": {
                          "type": "array",
                          "items": { "type": "string", "minLength": 1 }
                        },
                        "dropped": {
                          "type": "array",
                          "items": { "type": "string", "minLength": 1 }
                        }
                      },
                      "required": ["kept", "dropped"],
                      "additionalProperties": false
                    }
                  },
                  "additionalProperties": false
                }
              },
              "required": ["dropped_lanes", "narrowed_by"],
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "required": ["system", "builds"],
      "additionalProperties": false
    },
    "spack_block": {
      "type": "object",
      "properties": {
        "version": { "type": "string", "minLength": 1, "description": "`spack --version` on the build host." },
        "commit": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "pattern": "^[0-9a-f]{7,64}$" }
          ],
          "description": "Exact Spack git commit if Spack is a checkout; null otherwise."
        },
        "package_repos": {
          "type": "array",
          "description": "Stack-owned repos registered for this build.",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "namespace": { "type": "string", "minLength": 1 },
              "path": { "type": "string", "minLength": 1 },
              "commit": { "type": "string", "pattern": "^[0-9a-f]{7,64}$" }
            },
            "required": ["name", "namespace", "path", "commit"],
            "additionalProperties": false
          }
        }
      },
      "required": ["version"],
      "additionalProperties": false
    },
    "build_host_block": {
      "type": "object",
      "properties": {
        "hostname": { "type": "string", "minLength": 1 },
        "os": { "type": "string", "minLength": 1 },
        "os_major": { "type": "integer", "minimum": 0 },
        "glibc": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$" },
        "cpu": { "type": "string", "minLength": 1 }
      },
      "required": ["hostname", "os", "os_major", "glibc", "cpu"],
      "additionalProperties": false
    },
    "lane_entry": {
      "type": "object",
      "description": "One rendered lane. Render-filled fields are always required; publish-filled fields become required only when phase=final.",
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "source_build": { "type": "string", "minLength": 1, "description": "stack.yaml.builds[*].name that produced this lane." },
        "env_path": { "type": "string", "minLength": 1, "description": "Path to the rendered environment, e.g., environments/gcc/core." },
        "kind": { "type": "string", "minLength": 1 },
        "compiler": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "runtime_node_type": { "type": "string", "minLength": 1 },
        "spec_source": {
          "type": "string",
          "pattern": "^(package_set:|inline:)",
          "description": "Spec source identifier. Format: 'package_set:<name>' or 'inline:<build>'."
        },
        "view_root": { "type": "string", "pattern": "^/" },
        "package_module_root": { "type": "string", "pattern": "^/" },
        "lockfile": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ],
          "description": "Publish-filled: relative path to the lane's spack.lock."
        },
        "lockfile_digest": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/sha256_digest" }
          ],
          "description": "Publish-filled."
        },
        "install_root": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "pattern": "^/" }
          ],
          "description": "Publish-filled."
        },
        "provenance_summary": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/provenance_summary" }
          ],
          "description": "Publish-filled: counts of packages by provenance class."
        },
        "platform_module_prereqs": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          ],
          "description": "Publish-filled: platform modules the public entry module checks/prereqs."
        }
      },
      "required": [
        "name",
        "source_build",
        "env_path",
        "kind",
        "compiler",
        "target",
        "runtime_node_type",
        "spec_source",
        "view_root",
        "package_module_root"
      ],
      "additionalProperties": false
    },
    "lane_entry_final_requirements": {
      "type": "object",
      "required": [
        "lockfile",
        "lockfile_digest",
        "install_root",
        "provenance_summary",
        "platform_module_prereqs"
      ],
      "properties": {
        "lockfile": { "type": "string", "minLength": 1 },
        "lockfile_digest": { "$ref": "#/$defs/sha256_digest" },
        "install_root": { "type": "string", "pattern": "^/" },
        "provenance_summary": { "$ref": "#/$defs/provenance_summary" },
        "platform_module_prereqs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "provenance_summary": {
      "type": "object",
      "description": "Counts of packages by provenance class.",
      "properties": {
        "stack_built": { "type": "integer", "minimum": 0 },
        "platform_backed": { "type": "integer", "minimum": 0 },
        "site_external": { "type": "integer", "minimum": 0 },
        "spack_built": { "type": "integer", "minimum": 0 }
      },
      "required": ["stack_built", "platform_backed", "site_external", "spack_built"],
      "additionalProperties": false
    },
    "verification_block": {
      "type": "object",
      "properties": {
        "spack_verify_libraries": {
          "type": "string",
          "enum": ["passed", "failed", "skipped"]
        },
        "spack_verify_manifest": {
          "type": "string",
          "enum": ["passed", "failed", "skipped"]
        },
        "site_smoke_tests": {
          "type": "string",
          "enum": ["passed", "failed", "skipped"]
        },
        "notes": { "type": "string" }
      },
      "required": [
        "spack_verify_libraries",
        "spack_verify_manifest",
        "site_smoke_tests"
      ],
      "additionalProperties": false
    }
  }
}

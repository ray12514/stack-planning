{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spack-composer.example/schemas/stack-defaults-v1.json",
  "title": "Spack stack defaults (v1)",
  "description": "Template-set defaults merged underneath the user's stack.yaml. Same shape as stack.yaml except: `name` is forbidden, `templates.set` is forbidden, `builds` is omitted in normal use, and `spack.floor` is required. Mirrors docs/spack_stack_generation_design_v6.md § Stack Defaults Merge Rules.",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Defaults schema version. Matches stack-v1."
    },
    "profile_contract": {
      "type": "object",
      "description": "Profile-version contract inherited by the user stack unless overridden.",
      "properties": {
        "schema_version": {
          "type": "integer",
          "minimum": 1,
          "description": "Profile schema version this template set targets."
        }
      },
      "additionalProperties": false
    },
    "templates": {
      "type": "object",
      "description": "Template-set self-reference is forbidden in defaults (the user stack picks the set). This block is reserved and must be empty.",
      "properties": {},
      "additionalProperties": false
    },
    "spack": {
      "type": "object",
      "description": "Spack version floor for this template set. Required.",
      "properties": {
        "floor": {
          "type": "string",
          "minLength": 1,
          "description": "Minimum Spack version the templates' features require. stack.yaml.spack.version may tighten this; never widen."
        }
      },
      "required": ["floor"],
      "additionalProperties": false
    },
    "modules": {
      "$ref": "#/$defs/modules_block"
    },
    "builds": {
      "type": "array",
      "description": "Build requests should normally be omitted from defaults; the user stack supplies them. A starter may include an inline list for documentation, but a shared defaults file should leave this empty so the user list always wins on merge.",
      "items": {
        "$ref": "#/$defs/build_request"
      }
    },
    "per_system": {
      "type": "object",
      "description": "Per-system narrowing defaults. Merges with user per_system by system name and build name.",
      "patternProperties": {
        "^[a-z][a-z0-9_-]*$": {
          "$ref": "#/$defs/per_system_entry"
        }
      },
      "additionalProperties": false
    },
    "externals": {
      "$ref": "#/$defs/externals_block"
    },
    "foundation_pins": {
      "type": "object",
      "description": "Library version pins for the common scope. Keys are package names; values are exact versions.",
      "patternProperties": {
        "^[a-z0-9][a-z0-9._-]*$": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "buildcache": {
      "$ref": "#/$defs/buildcache_block"
    },
    "release": {
      "$ref": "#/$defs/release_block"
    },
    "helpers": {
      "$ref": "#/$defs/helpers_block"
    },
    "helper_recommendations": {
      "type": "object",
      "description": "Free-form hints displayed by spack-composer explain.",
      "additionalProperties": true
    },
    "package_repositories": {
      "type": "array",
      "description": "Default package-repository selection. The user stack may add or replace entries.",
      "items": {
        "$ref": "#/$defs/package_repository"
      }
    }
  },
  "required": ["schema_version", "spack"],
  "additionalProperties": false,
  "$defs": {
    "modules_block": {
      "type": "object",
      "properties": {
        "format": {
          "type": "string",
          "enum": ["tcl"]
        },
        "additional_formats": {
          "type": "array",
          "items": { "type": "string", "enum": ["lmod"] },
          "uniqueItems": true
        },
        "exposure": {
          "type": "string",
          "enum": ["front_door", "direct"],
          "default": "front_door"
        },
        "init_module": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "module_root": {
          "type": "string",
          "minLength": 1
        },
        "publish_root": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "pattern": "^/" }
          ]
        },
        "hierarchy_style": {
          "type": "string",
          "enum": ["collapsed", "granular"],
          "default": "collapsed"
        },
        "expose_provenance": {
          "type": "boolean",
          "default": true
        },
        "platform_module_policy": {
          "type": "string",
          "enum": ["prereq", "autoload"],
          "default": "prereq"
        }
      },
      "additionalProperties": false
    },
    "build_request": {
      "type": "object",
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "class": { "type": "string", "minLength": 1 },
        "package_set": { "type": "string", "minLength": 1 },
        "specs": {
          "oneOf": [
            { "type": "array", "items": { "type": "string", "minLength": 1 } },
            {
              "type": "object",
              "patternProperties": {
                "^(any|[a-z][a-z0-9_-]*)$": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 }
                }
              },
              "additionalProperties": false
            },
            { "type": "null" }
          ]
        },
        "toolchain": { "type": "string", "minLength": 1 },
        "nodes": { "type": "string", "minLength": 1 },
        "expand": {
          "type": "string",
          "enum": ["one", "per_node_type", "per_cpu_target", "per_gpu_arch"]
        },
        "publish": { "type": "boolean", "default": true },
        "required": { "type": "boolean", "default": false }
      },
      "required": ["name", "class", "toolchain", "nodes", "expand"],
      "additionalProperties": false
    },
    "per_system_entry": {
      "type": "object",
      "properties": {
        "builds": {
          "type": "object",
          "patternProperties": {
            "^[a-z][a-z0-9_-]*$": {
              "type": "object",
              "properties": {
                "compilers": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 },
                  "minItems": 1,
                  "uniqueItems": true
                },
                "mpi": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 },
                  "minItems": 1,
                  "uniqueItems": true
                },
                "gpu_arch": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 },
                  "minItems": 1,
                  "uniqueItems": true
                }
              },
              "additionalProperties": false,
              "minProperties": 1
            }
          },
          "additionalProperties": false
        }
      },
      "required": ["builds"],
      "additionalProperties": false
    },
    "externals_block": {
      "type": "object",
      "properties": {
        "compilers": {
          "type": "string",
          "enum": ["prefer_platform", "build_all", "mixed"]
        },
        "mpi": {
          "type": "string",
          "enum": ["prefer_platform", "build_all", "mixed"]
        },
        "openssl": {
          "type": "string",
          "enum": ["system", "stack_built"]
        },
        "curl": {
          "type": "string",
          "enum": ["system", "stack_built"]
        },
        "fabric_userspace": {
          "type": "string",
          "enum": ["prefer_platform", "build_all", "mixed"],
          "default": "prefer_platform"
        },
        "gpu_toolkit": {
          "type": "string",
          "enum": ["prefer_platform", "build_all", "mixed"],
          "default": "prefer_platform"
        }
      },
      "required": ["compilers", "mpi", "openssl", "curl"],
      "additionalProperties": false
    },
    "buildcache_block": {
      "type": "object",
      "properties": {
        "spack_generation": { "type": "string", "minLength": 1 },
        "foundation_lane": { "type": "string", "minLength": 1 },
        "payload_lane": { "type": "string", "minLength": 1 },
        "signed": { "type": "boolean", "default": false },
        "push_after_every_step": { "type": "boolean", "default": true }
      },
      "required": ["spack_generation", "payload_lane"],
      "additionalProperties": false
    },
    "release_block": {
      "type": "object",
      "properties": {
        "save_lockfiles": { "type": "boolean" },
        "save_manifest": { "type": "boolean" },
        "retain_previous": {
          "type": "integer",
          "minimum": 0,
          "default": 2
        },
        "promotion": {
          "type": "string",
          "enum": ["gated_manual", "auto"],
          "default": "gated_manual"
        }
      },
      "required": ["save_lockfiles", "save_manifest"],
      "additionalProperties": false
    },
    "helpers_block": {
      "type": "object",
      "properties": {
        "inspector": {
          "type": "string",
          "enum": ["available", "preferred", "disabled"],
          "default": "available"
        },
        "render": {
          "type": "string",
          "enum": ["available", "preferred", "disabled"],
          "default": "available"
        },
        "ansible": {
          "type": "string",
          "enum": ["available", "preferred", "disabled"],
          "default": "available"
        }
      },
      "additionalProperties": false
    },
    "package_repository": {
      "type": "object",
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "namespace": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "priority": {
          "type": "string",
          "enum": ["before_builtin", "after_builtin"],
          "default": "before_builtin"
        }
      },
      "required": ["name", "namespace", "path"],
      "additionalProperties": false
    }
  }
}

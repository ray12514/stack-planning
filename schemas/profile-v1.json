{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spack-composer.example/schemas/profile-v1.json",
  "title": "Spack stack system profile (v1)",
  "description": "Observed system facts consumed by the spack-composer renderer. Produced by cluster-inspector or written by hand. Cross-repo contract between whoever produces system facts and the stack repository that consumes them. Mirrors docs/spack_stack_generation_design_v6.md § profile.yaml.",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Profile schema version. v1 is this file; future bumps live as profile-v2.json alongside."
    },
    "system": {
      "type": "object",
      "description": "Identity block. Identifies the system as a whole.",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Short system identifier; used in release paths."
        },
        "family": {
          "type": "string",
          "minLength": 1,
          "description": "System family (e.g., cray-rhel, linux-sles, linux-rhel9). Open vocabulary; the contract resolver matches against this string."
        },
        "description": {
          "type": "string",
          "description": "Free-form, surfaces in release-manifest only."
        }
      },
      "required": ["name", "family"],
      "additionalProperties": false
    },
    "os": {
      "type": "object",
      "description": "OS identity. Controls cache keying alongside glibc.",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Lowercase distro id (rhel, sles, ubuntu, rocky, almalinux, etc.). Open vocabulary."
        },
        "major": {
          "type": "integer",
          "minimum": 0,
          "description": "Major version integer."
        },
        "minor": {
          "type": "integer",
          "minimum": 0,
          "description": "Minor version integer. Used only in release-manifest."
        },
        "glibc": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$",
          "description": "Exact glibc version string. Decides cache compatibility."
        }
      },
      "required": ["name", "major", "glibc"],
      "additionalProperties": false
    },
    "fabric": {
      "type": "object",
      "description": "Fabric stack: kernel/userspace drivers plus optional userspace libraries.",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["slingshot", "infiniband", "roce", "omnipath", "ethernet"],
          "description": "Fabric type."
        },
        "generation": {
          "type": "string",
          "description": "Fabric generation marker (cxi, hdr, ndr, etc.). Omit for ethernet."
        },
        "drivers": {
          "type": "array",
          "description": "Kernel/userspace driver libraries (externals).",
          "items": {
            "$ref": "#/$defs/named_prefix_versioned"
          }
        },
        "userspace": {
          "type": "array",
          "description": "Userspace libraries such as libfabric and UCX. Empty list if absent.",
          "items": {
            "$ref": "#/$defs/named_prefix_versioned"
          }
        }
      },
      "required": ["type", "drivers"],
      "additionalProperties": false
    },
    "modules_system": {
      "type": "object",
      "description": "Module tool present on the system.",
      "properties": {
        "tool": {
          "type": "string",
          "enum": ["tcl", "lmod"],
          "description": "Module tool."
        },
        "version": {
          "type": "string",
          "description": "Tool version. Used only in release-manifest."
        }
      },
      "required": ["tool"],
      "additionalProperties": false
    },
    "vendor_cray": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/vendor_cray_block" }
      ],
      "description": "Present only on Cray-family systems; explicit null otherwise."
    },
    "compilers_external": {
      "type": "array",
      "description": "Generic site or system compilers as externals. Excludes Cray PE compilers (those live under vendor_cray).",
      "items": {
        "$ref": "#/$defs/compiler_external"
      }
    },
    "mpi": {
      "type": "array",
      "description": "Generic MPI implementations available on the system. Excludes cray-mpich (lives under vendor_cray).",
      "items": {
        "$ref": "#/$defs/mpi_external"
      }
    },
    "gpu_toolkit_modules": {
      "type": "object",
      "description": "Standalone GPU toolkit modules separable from a vendor PrgEnv. Used by the Cray PE Option B GPU lane.",
      "properties": {
        "rocm": { "$ref": "#/$defs/rocm_toolkit_module" },
        "cudatoolkit": { "$ref": "#/$defs/cuda_toolkit_module" },
        "nvhpc": { "$ref": "#/$defs/nvhpc_toolkit_module" }
      },
      "additionalProperties": false
    },
    "filesystem": {
      "type": "object",
      "description": "Install-tree and shared-storage candidates.",
      "properties": {
        "install_tree_candidates": {
          "type": "array",
          "description": "Shared filesystems suitable for the install tree.",
          "minItems": 1,
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "pattern": "^/",
                "description": "Absolute path."
              },
              "type": {
                "type": "string",
                "description": "Filesystem type (e.g., lustre, gpfs, nfs)."
              },
              "locks_honored": {
                "type": "boolean",
                "description": "True if file locks are reliable here."
              },
              "free_gb": {
                "type": "integer",
                "minimum": 0,
                "description": "Free capacity in GB."
              }
            },
            "required": ["path", "type", "locks_honored"],
            "additionalProperties": false
          }
        },
        "source_cache_candidate": {
          "type": "string",
          "pattern": "^/",
          "description": "Absolute path to a candidate Spack source-cache location."
        },
        "buildcache_candidate": {
          "type": "string",
          "pattern": "^/",
          "description": "Absolute path to a candidate buildcache location."
        }
      },
      "required": ["install_tree_candidates"],
      "additionalProperties": false
    },
    "node_types": {
      "type": "object",
      "description": "One entry per node class on the system. Keys are operator-chosen node-type names; values are the per-class facts.",
      "minProperties": 1,
      "patternProperties": {
        "^[a-z][a-z0-9_]*$": {
          "$ref": "#/$defs/node_type"
        }
      },
      "additionalProperties": false
    },
    "capabilities": {
      "type": "object",
      "description": "Derived flags the stack consults. Computed by the inspector or written by hand.",
      "properties": {
        "lanes_capable": {
          "type": "array",
          "description": "Which (compiler, lane, runtime_node_types) tuples are valid for this profile.",
          "items": {
            "type": "object",
            "properties": {
              "compiler": {
                "type": "string",
                "description": "Compiler id (gcc, cce, aocc, rocmcc, nvhpc, intel, etc.)."
              },
              "lane": {
                "type": "string",
                "description": "Lane label matching template contract vocabulary (core, serial, mpi-craympich, gpu-craympich-<arch>, mpi-openmpi, etc.)."
              },
              "runtime_node_types": {
                "type": "array",
                "description": "Node-type names where this lane can run. Must reference keys present in node_types.",
                "items": { "type": "string" },
                "minItems": 1
              }
            },
            "required": ["compiler", "lane", "runtime_node_types"],
            "additionalProperties": false
          }
        },
        "gpu_lane_supported": {
          "type": "boolean",
          "description": "True if any node_type carries a gpu block."
        },
        "fabric_class": {
          "type": "string",
          "enum": ["vendor_tuned", "open", "ethernet_only"],
          "description": "Derived fabric posture."
        }
      },
      "required": ["lanes_capable"],
      "additionalProperties": false
    }
  },
  "required": [
    "schema_version",
    "system",
    "os",
    "fabric",
    "modules_system",
    "filesystem",
    "node_types",
    "capabilities"
  ],
  "additionalProperties": false,
  "$defs": {
    "named_prefix_versioned": {
      "type": "object",
      "description": "Library or driver entry with name, version, and install prefix.",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Library or driver name."
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "description": "Version string."
        },
        "prefix": {
          "type": "string",
          "pattern": "^/",
          "description": "Absolute install prefix."
        }
      },
      "required": ["name", "version", "prefix"],
      "additionalProperties": false
    },
    "compiler_external": {
      "type": "object",
      "description": "A generic site or system compiler external.",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Compiler name (gcc, aocc, intel, oneapi, nvhpc, etc.)."
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "description": "Exact compiler version."
        },
        "prefix": {
          "type": "string",
          "pattern": "^/",
          "description": "Absolute compiler install prefix."
        },
        "modules": {
          "type": "array",
          "description": "Modules to load to expose this compiler. Omit for prefix-only externals.",
          "items": { "type": "string" }
        },
        "languages": {
          "type": "array",
          "description": "Languages the compiler provides drivers for.",
          "items": {
            "type": "string",
            "enum": ["c", "c++", "fortran"]
          },
          "uniqueItems": true,
          "minItems": 1
        }
      },
      "required": ["name", "version", "prefix", "languages"],
      "additionalProperties": false
    },
    "mpi_external": {
      "type": "object",
      "description": "A generic MPI implementation external. Excludes cray-mpich.",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "MPI provider (openmpi, mpich, mvapich, intel-mpi, etc.)."
        },
        "provenance": {
          "type": "string",
          "enum": ["site", "system", "vendor_bundled", "absent"],
          "description": "Where the MPI install came from."
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "description": "Exact MPI version."
        },
        "prefix": {
          "type": "string",
          "pattern": "^/",
          "description": "Absolute MPI install prefix."
        },
        "compiler": {
          "type": "string",
          "description": "Compiler spec the site MPI was built with (e.g., aocc@4.2.0)."
        },
        "modules": {
          "type": "array",
          "description": "Modules to load to expose this MPI. Omit when prefix is sufficient.",
          "items": { "type": "string" }
        }
      },
      "required": ["name", "provenance", "version", "prefix"],
      "additionalProperties": false
    },
    "vendor_cray_block": {
      "type": "object",
      "description": "Cray PE facts. Each optional compiler sub-block (cce, gcc, rocmcc, nvhpc) is present only when that compiler is exposed on the system.",
      "properties": {
        "pe_version": {
          "type": "string",
          "minLength": 1,
          "description": "Cray PE release this profile is pinned to."
        },
        "cce": { "$ref": "#/$defs/cray_compiler_block" },
        "gcc": { "$ref": "#/$defs/cray_compiler_block" },
        "rocmcc": { "$ref": "#/$defs/cray_compiler_block" },
        "nvhpc": { "$ref": "#/$defs/cray_compiler_block" },
        "cray_mpich": { "$ref": "#/$defs/cray_mpich_block" },
        "libsci": { "$ref": "#/$defs/cray_libsci_block" }
      },
      "required": ["pe_version"],
      "additionalProperties": false
    },
    "cray_compiler_block": {
      "type": "object",
      "description": "A Cray-exposed compiler (CCE, Cray-native GCC, ROCmCC, NVHPC).",
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1,
          "description": "Compiler version."
        },
        "prefix": {
          "type": "string",
          "pattern": "^/",
          "description": "Absolute compiler install prefix."
        },
        "modules": {
          "type": "array",
          "description": "Module list the external loads at build time (e.g., [PrgEnv-cray, cce/17.0.1]).",
          "items": { "type": "string" },
          "minItems": 1
        }
      },
      "required": ["version", "prefix", "modules"],
      "additionalProperties": false
    },
    "cray_mpich_block": {
      "type": "object",
      "description": "cray-mpich with per-compiler flavor prefixes.",
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1,
          "description": "cray-mpich version."
        },
        "flavors": {
          "type": "object",
          "description": "Compiler-flavored builds at distinct prefixes. Keys are compiler names (cce, gcc, rocmcc, nvhpc).",
          "minProperties": 1,
          "patternProperties": {
            "^[a-z][a-z0-9_]*$": {
              "type": "object",
              "properties": {
                "prefix": {
                  "type": "string",
                  "pattern": "^/",
                  "description": "Absolute prefix for this compiler-flavored build."
                },
                "modules": {
                  "type": "array",
                  "description": "Modules to load to expose this flavor.",
                  "items": { "type": "string" },
                  "minItems": 1
                }
              },
              "required": ["prefix", "modules"],
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "required": ["version", "flavors"],
      "additionalProperties": false
    },
    "cray_libsci_block": {
      "type": "object",
      "description": "cray-libsci facts.",
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1,
          "description": "libsci version."
        },
        "prefix": {
          "type": "string",
          "pattern": "^/",
          "description": "Absolute libsci install prefix."
        }
      },
      "additionalProperties": false
    },
    "rocm_toolkit_module": {
      "type": "object",
      "description": "ROCm standalone toolkit module plus Spack component externals.",
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1,
          "description": "ROCm version."
        },
        "module": {
          "type": "string",
          "minLength": 1,
          "description": "Module name (e.g., rocm/6.0.0)."
        },
        "prefix": {
          "type": "string",
          "pattern": "^/",
          "description": "Absolute ROCm install prefix."
        },
        "spack_components": {
          "type": "array",
          "description": "ROCm component externals (hip, hsa-rocr-dev, comgr, rocblas, hipblas, hipsparse, rocprim, llvm-amdgpu, etc.).",
          "items": {
            "type": "object",
            "properties": {
              "package": {
                "type": "string",
                "minLength": 1,
                "description": "Spack package name."
              },
              "prefix": {
                "type": "string",
                "pattern": "^/",
                "description": "Absolute component install prefix."
              }
            },
            "required": ["package", "prefix"],
            "additionalProperties": false
          },
          "minItems": 1
        }
      },
      "required": ["version", "module", "prefix", "spack_components"],
      "additionalProperties": false
    },
    "cuda_toolkit_module": {
      "type": "object",
      "description": "CUDA standalone toolkit module.",
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1,
          "description": "CUDA toolkit version."
        },
        "module": {
          "type": "string",
          "minLength": 1,
          "description": "Module name (e.g., cudatoolkit/12.4)."
        },
        "prefix": {
          "type": "string",
          "pattern": "^/",
          "description": "Absolute CUDA install prefix."
        }
      },
      "required": ["version", "module", "prefix"],
      "additionalProperties": false
    },
    "nvhpc_toolkit_module": {
      "type": "object",
      "description": "NVHPC as a standalone toolkit module (no PrgEnv switch).",
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1,
          "description": "NVHPC version."
        },
        "module": {
          "type": "string",
          "minLength": 1,
          "description": "Module name (e.g., nvhpc/24.5)."
        },
        "prefix": {
          "type": "string",
          "pattern": "^/",
          "description": "Absolute NVHPC install prefix."
        }
      },
      "required": ["version", "module", "prefix"],
      "additionalProperties": false
    },
    "node_type": {
      "type": "object",
      "description": "Per-node-class facts: role, CPU, GPU (or null), build-stage candidates.",
      "properties": {
        "role": {
          "type": "string",
          "enum": ["build_host", "runtime", "both"],
          "description": "Whether this class can host Spack builds, run payloads, or both."
        },
        "description": {
          "type": "string",
          "description": "Free-form description of the node class."
        },
        "cpu": {
          "type": "object",
          "description": "Microarchitecture facts for this node class.",
          "properties": {
            "detected": {
              "type": "string",
              "minLength": 1,
              "description": "What archspec sees on this class (e.g., zen3, sm_90, sapphirerapids)."
            },
            "preferred": {
              "type": "string",
              "minLength": 1,
              "description": "Target this class would compile to."
            },
            "alternates": {
              "type": "array",
              "description": "Other targets reachable on this class.",
              "items": { "type": "string" }
            }
          },
          "required": ["detected", "preferred"],
          "additionalProperties": false
        },
        "gpu": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/gpu_block" }
          ],
          "description": "GPU facts when present; explicit null when this class has no GPU."
        },
        "build_stage": {
          "type": "array",
          "description": "Writable fast paths for this class.",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1,
                "description": "Path; may include $tempdir or $user-style placeholders or be absolute."
              },
              "visibility": {
                "type": "string",
                "enum": ["shared", "compute-only", "node-local", "unknown"],
                "description": "Scope of visibility for this path."
              },
              "writable": {
                "type": "boolean",
                "description": "Confirmed writable by the producer."
              },
              "free_gb": {
                "type": "integer",
                "minimum": 0,
                "description": "Free capacity in GB."
              },
              "free_inodes": {
                "type": "integer",
                "minimum": 0,
                "description": "Free inode count."
              },
              "mount_opts": {
                "type": "array",
                "description": "Mount options observed on this path.",
                "items": { "type": "string" }
              },
              "throughput_class": {
                "type": "string",
                "enum": ["fast", "medium", "slow", "unknown"],
                "description": "Coarse throughput class."
              }
            },
            "required": ["path", "visibility", "writable"],
            "additionalProperties": false
          },
          "minItems": 1
        }
      },
      "required": ["role", "cpu", "gpu", "build_stage"],
      "additionalProperties": false
    },
    "gpu_block": {
      "type": "object",
      "description": "GPU facts for a node class.",
      "properties": {
        "vendor": {
          "type": "string",
          "enum": ["amd", "nvidia"],
          "description": "GPU vendor."
        },
        "driver_version": {
          "type": "string",
          "minLength": 1,
          "description": "Kernel driver version on this class."
        },
        "toolkit_ceiling": {
          "type": "string",
          "minLength": 1,
          "description": "Maximum toolkit version the driver supports."
        },
        "arch_target": {
          "type": "string",
          "minLength": 1,
          "description": "Arch label: AMD gfx90a/gfx942 or NVIDIA sm_80/sm_90/etc."
        },
        "cuda_compat_available": {
          "type": "boolean",
          "default": false,
          "description": "NVIDIA only: whether the CUDA compatibility library is installed."
        }
      },
      "required": ["vendor", "driver_version", "toolkit_ceiling", "arch_target"],
      "additionalProperties": false
    }
  }
}

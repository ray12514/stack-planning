{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stack-composer.example/schemas/profile-v1.json",
  "title": "Spack stack system profile (v1)",
  "description": "Observed system facts consumed by the stack-composer renderer. Produced by cluster-inspector or written by hand. Cross-repo contract between whoever produces system facts and the stack repository that consumes them. Mirrors docs/spack_stack_generation_design_v6.md § profile.yaml.",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Profile schema version. v1 is this file; future bumps live as profile-v2.json alongside."
    },
    "system": {
      "type": "object",
      "description": "Identity block. Identifies the system as a whole.",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Short system identifier; used in release paths."
        },
        "family": {
          "type": "string",
          "minLength": 1,
          "description": "System family (e.g., cray-rhel, linux-sles, linux-rhel9). Open vocabulary; the contract resolver matches against this string."
        },
        "description": {
          "type": "string",
          "description": "Free-form, surfaces in release-manifest only."
        }
      },
      "required": ["name", "family"],
      "additionalProperties": false
    },
    "os": {
      "type": "object",
      "description": "OS identity. Controls cache keying alongside glibc.",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Lowercase distro id (rhel, sles, ubuntu, rocky, almalinux, etc.). Open vocabulary."
        },
        "major": {
          "type": "integer",
          "minimum": 0,
          "description": "Major version integer."
        },
        "minor": {
          "type": "integer",
          "minimum": 0,
          "description": "Minor version integer. Used only in release-manifest."
        },
        "glibc": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$",
          "description": "Exact glibc version string. Decides cache compatibility."
        }
      },
      "required": ["name", "major", "glibc"],
      "additionalProperties": false
    },
    "fabric": {
      "type": "object",
      "description": "Fabric stack: kernel/userspace drivers plus optional userspace libraries.",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["slingshot", "infiniband", "roce", "omnipath", "ethernet"],
          "description": "Fabric type."
        },
        "generation": {
          "type": "string",
          "description": "Fabric generation marker (cxi, hdr, ndr, etc.). Omit for ethernet."
        },
        "drivers": {
          "type": "array",
          "description": "Kernel/userspace driver libraries (externals).",
          "items": {
            "$ref": "#/$defs/named_prefix_versioned"
          }
        },
        "userspace": {
          "type": "array",
          "description": "Userspace libraries such as libfabric and UCX. Empty list if absent.",
          "items": {
            "$ref": "#/$defs/named_prefix_versioned"
          }
        }
      },
      "required": ["type", "drivers"],
      "additionalProperties": false
    },
    "modules_system": {
      "type": "object",
      "description": "Module tool present on the system.",
      "properties": {
        "tool": {
          "type": "string",
          "enum": ["tcl", "lmod"],
          "description": "Module tool."
        },
        "version": {
          "type": "string",
          "description": "Tool version. Used only in release-manifest."
        }
      },
      "required": ["tool"],
      "additionalProperties": false
    },
    "compiler_providers": {
      "type": "array",
      "description": "Every compiler available on the system as an external, each tagged with the provider family it comes from. Generic: Cray PE compilers are provider_family=cray-pe entries, not a special block.",
      "items": {
        "$ref": "#/$defs/compiler_provider"
      }
    },
    "mpi_providers": {
      "type": "array",
      "description": "Every MPI implementation available on the system, each tagged with provider family. A provider is single-prefix or carries per-compiler flavors (e.g. cray-mpich). Generic across Cray PE, other vendor PEs, site builds, and OS packages.",
      "items": {
        "$ref": "#/$defs/mpi_provider"
      }
    },
    "gpu_toolkit_modules": {
      "type": "object",
      "description": "Standalone GPU toolkit modules separable from a vendor PrgEnv. Used by the Cray PE Option B GPU lane.",
      "properties": {
        "rocm": { "$ref": "#/$defs/rocm_toolkit_module" },
        "cudatoolkit": { "$ref": "#/$defs/cuda_toolkit_module" },
        "nvhpc": { "$ref": "#/$defs/nvhpc_toolkit_module" }
      },
      "additionalProperties": false
    },
    "filesystem": {
      "type": "object",
      "description": "Install-tree and shared-storage candidates.",
      "properties": {
        "install_tree_candidates": {
          "type": "array",
          "description": "Shared filesystems suitable for the install tree.",
          "minItems": 1,
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "pattern": "^/",
                "description": "Absolute path."
              },
              "type": {
                "type": "string",
                "description": "Filesystem type (e.g., lustre, gpfs, nfs)."
              },
              "locks_honored": {
                "type": "boolean",
                "description": "True if file locks are reliable here."
              },
              "free_gb": {
                "type": "integer",
                "minimum": 0,
                "description": "Free capacity in GB."
              }
            },
            "required": ["path", "type", "locks_honored"],
            "additionalProperties": false
          }
        },
        "source_cache_candidate": {
          "type": "string",
          "pattern": "^/",
          "description": "Absolute path to a candidate Spack source-cache location."
        },
        "buildcache_candidate": {
          "type": "string",
          "pattern": "^/",
          "description": "Absolute path to a candidate buildcache location."
        }
      },
      "required": ["install_tree_candidates"],
      "additionalProperties": false
    },
    "node_types": {
      "type": "object",
      "description": "One entry per node class on the system. Keys are operator-chosen node-type names; values are the per-class facts.",
      "minProperties": 1,
      "patternProperties": {
        "^[a-z][a-z0-9_]*$": {
          "$ref": "#/$defs/node_type"
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "schema_version",
    "system",
    "os",
    "fabric",
    "modules_system",
    "filesystem",
    "node_types"
  ],
  "additionalProperties": false,
  "$defs": {
    "named_prefix_versioned": {
      "type": "object",
      "description": "Library or driver entry with name, version, and install prefix.",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Library or driver name."
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "description": "Version string."
        },
        "prefix": {
          "type": "string",
          "pattern": "^/",
          "description": "Absolute install prefix."
        }
      },
      "required": ["name", "version", "prefix"],
      "additionalProperties": false
    },
    "provider_family": {
      "type": "string",
      "enum": ["cray-pe", "platform", "site", "system"],
      "description": "Where a provider comes from: cray-pe (Cray PE / a future CPE), platform (another vendor PE), site (site-built/module), system (OS package)."
    },
    "compiler_provider": {
      "type": "object",
      "description": "One compiler available as an external, tagged with its provider family.",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Compiler name (gcc, cce, aocc, intel, nvhpc, ...)."
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "description": "Exact compiler version."
        },
        "prefix": {
          "type": "string",
          "pattern": "^/",
          "description": "Absolute compiler install prefix."
        },
        "provider_family": { "$ref": "#/$defs/provider_family" },
        "languages": {
          "type": "array",
          "description": "Languages the compiler provides drivers for.",
          "items": { "type": "string", "enum": ["c", "c++", "fortran"] },
          "uniqueItems": true,
          "minItems": 1
        },
        "modules": {
          "type": "array",
          "description": "Modules to load to expose this compiler (e.g. [PrgEnv-cray, cce/17.0.1]). Omit for prefix-only externals.",
          "items": { "type": "string" }
        },
        "compilers": {
          "type": "object",
          "description": "Optional explicit driver paths. Derived from prefix/bin + the template command map when omitted.",
          "properties": {
            "c": { "type": "string", "minLength": 1 },
            "cxx": { "type": "string", "minLength": 1 },
            "fortran": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        }
      },
      "required": ["name", "version", "prefix", "provider_family", "languages"],
      "additionalProperties": false
    },
    "mpi_provider": {
      "type": "object",
      "description": "One MPI implementation available as an external, tagged with provider family. Either single-prefix or per-compiler flavors.",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "MPI provider (cray-mpich, openmpi, mpich, mvapich2, intel-mpi, ...)."
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "description": "Exact MPI version."
        },
        "provider_family": { "$ref": "#/$defs/provider_family" },
        "prefix": {
          "type": "string",
          "pattern": "^/",
          "description": "Absolute MPI install prefix (single-flavor providers)."
        },
        "modules": {
          "type": "array",
          "description": "Modules to load to expose this MPI. Omit when prefix is sufficient.",
          "items": { "type": "string" }
        },
        "compiler": {
          "type": "string",
          "description": "Compiler this MPI was built with, for single-flavor site MPI (e.g. aocc@4.2.0)."
        },
        "compatibility": {
          "type": "object",
          "description": "Which compilers this MPI supports.",
          "properties": {
            "compilers": { "type": "array", "items": { "type": "string", "minLength": 1 } }
          },
          "additionalProperties": false
        },
        "flavors": {
          "type": "object",
          "description": "Per-compiler builds at distinct prefixes (e.g. cray-mpich). Keys are compiler names.",
          "minProperties": 1,
          "patternProperties": {
            "^[a-z][a-z0-9_]*$": {
              "type": "object",
              "properties": {
                "prefix": { "type": "string", "pattern": "^/" },
                "modules": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
              },
              "required": ["prefix", "modules"],
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "required": ["name", "version", "provider_family"],
      "additionalProperties": false
    },
    "rocm_toolkit_module": {
      "type": "object",
      "description": "ROCm standalone toolkit module plus Spack component externals.",
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1,
          "description": "ROCm version."
        },
        "module": {
          "type": "string",
          "minLength": 1,
          "description": "Module name (e.g., rocm/6.0.0)."
        },
        "prefix": {
          "type": "string",
          "pattern": "^/",
          "description": "Absolute ROCm install prefix."
        },
        "spack_components": {
          "type": "array",
          "description": "ROCm component externals (hip, hsa-rocr-dev, comgr, rocblas, hipblas, hipsparse, rocprim, llvm-amdgpu, etc.).",
          "items": {
            "type": "object",
            "properties": {
              "package": {
                "type": "string",
                "minLength": 1,
                "description": "Spack package name."
              },
              "prefix": {
                "type": "string",
                "pattern": "^/",
                "description": "Absolute component install prefix."
              }
            },
            "required": ["package", "prefix"],
            "additionalProperties": false
          },
          "minItems": 1
        }
      },
      "required": ["version", "module", "prefix", "spack_components"],
      "additionalProperties": false
    },
    "cuda_toolkit_module": {
      "type": "object",
      "description": "CUDA standalone toolkit module.",
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1,
          "description": "CUDA toolkit version."
        },
        "module": {
          "type": "string",
          "minLength": 1,
          "description": "Module name (e.g., cuda/12.4)."
        },
        "prefix": {
          "type": "string",
          "pattern": "^/",
          "description": "Absolute CUDA install prefix."
        }
      },
      "required": ["version", "module", "prefix"],
      "additionalProperties": false
    },
    "nvhpc_toolkit_module": {
      "type": "object",
      "description": "NVHPC module for explicit NVHPC compiler/toolkit exception lanes.",
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1,
          "description": "NVHPC version."
        },
        "module": {
          "type": "string",
          "minLength": 1,
          "description": "Module name (e.g., nvhpc/24.5)."
        },
        "prefix": {
          "type": "string",
          "pattern": "^/",
          "description": "Absolute NVHPC install prefix."
        }
      },
      "required": ["version", "module", "prefix"],
      "additionalProperties": false
    },
    "node_type": {
      "type": "object",
      "description": "Per-node-class facts: role, CPU, GPU (or null), build-stage candidates.",
      "properties": {
        "role": {
          "type": "string",
          "enum": ["build_host", "runtime", "both"],
          "description": "Whether this class can host Spack builds, run payloads, or both."
        },
        "description": {
          "type": "string",
          "description": "Free-form description of the node class."
        },
        "cpu": {
          "type": "object",
          "description": "Microarchitecture facts for this node class.",
          "properties": {
            "detected": {
              "type": "string",
              "minLength": 1,
              "description": "What archspec sees on this class (e.g., zen3, sm_90, sapphirerapids)."
            },
            "preferred": {
              "type": "string",
              "minLength": 1,
              "description": "Target this class would compile to."
            },
            "alternates": {
              "type": "array",
              "description": "Other targets reachable on this class.",
              "items": { "type": "string" }
            }
          },
          "required": ["detected", "preferred"],
          "additionalProperties": false
        },
        "gpu": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/gpu_block" }
          ],
          "description": "GPU facts when present; explicit null when this class has no GPU."
        },
        "build_stage": {
          "type": "array",
          "description": "Writable fast paths for this class.",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1,
                "description": "Path; may include $tempdir or $user-style placeholders or be absolute."
              },
              "visibility": {
                "type": "string",
                "enum": ["shared", "compute-only", "node-local", "unknown"],
                "description": "Scope of visibility for this path."
              },
              "writable": {
                "type": "boolean",
                "description": "Confirmed writable by the producer."
              },
              "free_gb": {
                "type": "integer",
                "minimum": 0,
                "description": "Free capacity in GB."
              },
              "free_inodes": {
                "type": "integer",
                "minimum": 0,
                "description": "Free inode count."
              },
              "mount_opts": {
                "type": "array",
                "description": "Mount options observed on this path.",
                "items": { "type": "string" }
              },
              "throughput_class": {
                "type": "string",
                "enum": ["fast", "medium", "slow", "unknown"],
                "description": "Coarse throughput class."
              }
            },
            "required": ["path", "visibility", "writable"],
            "additionalProperties": false
          },
          "minItems": 1
        }
      },
      "required": ["role", "cpu", "gpu", "build_stage"],
      "additionalProperties": false
    },
    "gpu_block": {
      "type": "object",
      "description": "GPU facts for a node class.",
      "properties": {
        "vendor": {
          "type": "string",
          "enum": ["amd", "nvidia"],
          "description": "GPU vendor."
        },
        "driver_version": {
          "type": "string",
          "minLength": 1,
          "description": "Kernel driver version on this class."
        },
        "toolkit_ceiling": {
          "type": "string",
          "minLength": 1,
          "description": "Maximum toolkit version the driver supports."
        },
        "arch_target": {
          "type": "string",
          "minLength": 1,
          "description": "Arch label: AMD gfx90a/gfx942 or NVIDIA sm_80/sm_90/etc."
        },
        "cuda_compat_available": {
          "type": "boolean",
          "default": false,
          "description": "NVIDIA only: whether the CUDA compatibility library is installed."
        }
      },
      "required": ["vendor", "driver_version", "toolkit_ceiling", "arch_target"],
      "additionalProperties": false
    }
  }
}
